<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/searchFragment">

    <fragment
        android:id="@+id/searchFragment"
        android:name="com.example.myapplication.presintation.SearchFragment"
        android:label="Search Route"
        tools:layout="@layout/fragment_search">
        <action
            android:id="@+id/action_searchFragment_to_routeFragment"
            app:destination="@id/routeFragment" />
    </fragment>

    <fragment
        android:id="@+id/routeFragment"
        android:name="com.example.myapplication.presintation.RouteFragment"
        android:label="Route Details"
        tools:layout="@layout/fragment_route">
        <argument
            android:name="startStation"
            app:argType="string" />
        <argument
            android:name="endStation"
            app:argType="string" />
    </fragment>
</navigation>