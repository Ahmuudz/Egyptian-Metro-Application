<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingHorizontal="16dp">

    <View
        android:id="@+id/viewLineTop"
        android:layout_width="4dp"
        android:layout_height="24dp"
        android:background="#A80000"
        app:layout_constraintEnd_toEndOf="@id/viewIndicator"
        app:layout_constraintStart_toStartOf="@id/viewIndicator"
        app:layout_constraintTop_toTopOf="parent" />

    <View
        android:id="@+id/viewIndicator"
        android:layout_width="12dp"
        android:layout_height="12dp"
        android:background="@drawable/shape_circle"
        android:backgroundTint="#A80000"
        app:layout_constraintBottom_toBottomOf="@id/cardStation"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/cardStation" />

    <View
        android:id="@+id/viewLineBottom"
        android:layout_width="4dp"
        android:layout_height="0dp"
        android:background="#A80000"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="@id/viewIndicator"
        app:layout_constraintStart_toStartOf="@id/viewIndicator"
        app:layout_constraintTop_toBottomOf="@id/viewIndicator" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardStation"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="0dp"
        app:strokeWidth="1dp"
        app:strokeColor="?attr/colorOutlineVariant"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/viewIndicator"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <TextView
                android:id="@+id/tvTransferHint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:textColor="#A80000"
                android:textStyle="bold"
                android:textSize="12sp"
                android:visibility="gone"
                tools:text="Transfer to Line 2"
                tools:visibility="visible" />

            <TextView
                android:id="@+id/tvStationName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                tools:text="Sadat" />

            <TextView
                android:id="@+id/tvLineName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                android:alpha="0.7"
                tools:text="First Line" />

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>